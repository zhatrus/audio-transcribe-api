# ── Transcription / models ────────────────────────────────
LANGUAGE=auto
MODEL_SIZE=medium
# cpu | gpu | cuda | auto  (gpu/cuda fall back to cpu if no CUDA)
DEVICE=gpu
# leave empty to auto-pick (float16 on GPU, int8 on CPU)
COMPUTE_TYPE=
# minutes the model stays in RAM/VRAM after last use (0 = never unload)
MODEL_IDLE_TIMEOUT_MIN=30

# Hugging Face token for pyannote diarization (optional)
HF_TOKEN=

# ── Job store / lifecycle ─────────────────────────────────
# base dir for uploads + cached results
DATA_DIR=/tmp/audio-transcribe-api
# hard auto-delete of any finished job, in hours
RESULT_TTL_HOURS=24
# delete this many hours after the result was first fetched
DELIVERED_TTL_HOURS=6
# how often the cleanup loop runs, in minutes
CLEANUP_INTERVAL_MIN=10
# reject uploads larger than this (MB); 0 = unlimited
MAX_UPLOAD_MB=1024

# ── Security ──────────────────────────────────────────────
# if set, every request must send header  X-API-Key: <value>
API_KEY=

# ── Webhook (optional) ────────────────────────────────────
# if set, the finished job (result or error) is POSTed here as JSON.
# A per-request `webhook_url` form field overrides this default.
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SEC=15

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# keep WORKERS=1 (single background worker model)
WORKERS=1
LOG_LEVEL=info
